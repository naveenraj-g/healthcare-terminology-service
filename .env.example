# Application
ENVIRONMENT=production

# PostgreSQL — asyncpg driver format required by SQLAlchemy
TERMINOLOGY_DATABASE_URL=postgresql+asyncpg://terminology_user:yourpassword@terminology-postgres:5432/terminology_db

# Postgres container env (used by docker-compose)
DB_HOST=terminology-postgres
DB_PORT=5432
DB_NAME=terminology_db
DB_USER=terminology_user
DB_PASSWORD=yourpassword

# Redis
REDIS_URL=redis://terminology-redis:6379/0
REDIS_HOST=terminology-redis
REDIS_PORT=6379
REDIS_DB=0

# Pool settings
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=50
DB_COMMAND_TIMEOUT=30
